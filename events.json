37b931ae5dcc9","authoredDate":"2024-11-08","serverPath":"https://assets.atdw-online.com.au/images/d3e5e4ef431913defad3c9907654c967.jpeg?rect=0%2C152%2C1600%2C900&w=800&h=450&rot=360&q=eyJ0eXBlIjoibGlzdGluZyIsImxpc3RpbmdJZCI6IjY1NTVhYmRkNTkwZGFhNjQyZTM3ZDM5YyIsImRpc3RyaWJ1dG9ySWQiOiI1NmIxZWI5MzQ0ZmVjYTNkZjJlMzIwY2IiLCJhcGlrZXlJZCI6IjU2YjFlZmVlMGNmMjEzYWQyMGRkMjE3MCJ9","attributeIdMultimediaContent":"IMAGE","attributeIdMultimediaContentDescription":"Image","attributeIdSizeOrientation":"16X9","width":"800","height":"450","altText":"boxing exhibitor at expo","caption":"","photographer":"","copyright":"","sequenceNumber":"400"},{"marketVariantId":"","multimediaId":"672c44fc47537b931ae5dcc9","authoredDate":"2024-11-08","serverPath":"https://assets.atdw-online.com.au/images/d3e5e4ef431913defad3c9907654c967.jpeg?rect=0%2C152%2C1600%2C900&w=280&h=158&rot=360&q=eyJ0eXBlIjoibGlzdGluZyIsImxpc3RpbmdJZCI6IjY1NTVhYmRkNTkwZGFhNjQyZTM3ZDM5YyIsImRpc3RyaWJ1dG9ySWQiOiI1NmIxZWI5MzQ0ZmVjYTNkZjJlMzIwY2IiLCJhcGlrZXlJZCI6IjU2YjFlZmVlMGNmMjEzYWQyMGRkMjE3MCJ9","attributeIdMultimediaContent":"IMAGE","attributeIdMultimediaContentDescription":"Image","attributeIdSizeOrientation":"16X9","width":"280","height":"158","altText":"boxing exhibitor at expo","caption":"","photographer":"","copyright":"","sequenceNumber":"400"},{"marketVariantId":"","multimediaId":"6555abdd590daa642e37d39c500","authoredDate":"2026-05-26","serverPath":"https://youtu.be/xtPb7qkEahA","videoId":"","videoThumbnailPath":"https://i.ytimg.com/vi/xtPb7qkEahA/mqdefault.jpg","videoThumbnailPathMaxRes":"","attributeIdMultimediaFile":"","attributeIdMultimediaFileDescription":"","attributeIdMultimediaContent":"VIDEO","attributeIdMultimediaContentDescription":"Video","attributeIdSizeOrientation":"","attributeIdSizeOrientationDescription":"","altText":"","multimediaDescription":"","sequenceNumber":"500"}],"openTimes":[],"productComments":[{"marketVariantId":"English / Global","attributeIdProductComment":"PRODTRANS ","attributeIdProductCommentDescription":"Product Description Translation","sequenceNumber":"","attributeIdLanguageWritten":"ENGLISH","attributeIdLanguageWrittenDescription":"English","commentText":"Join them at the RDE-Regional Disability with bonus Seniors Expo for a day filled with inspiration, information, and empowerment. This in-person event brings together a diverse community of individuals, families, and organizations dedicated to supporting people with disabilities and the aged care sector.\n\nDiscover the latest innovations in assistive technology, explore service providers, and connect with like-minded individuals. Learn about accessible recreation options, employment opportunities, and resources to enhance your well-being.\n\nWhether you're a person with a disability, a caregiver, or a professional in the field, the RDE-Regional Disability with bonus Seniors Expo is the place to be. Come and be part of a welcoming and inclusive environment where you can gain knowledge, make connections, and celebrate the abilities of all individuals.\n\nMark your calendar and get ready to embrace a day of insight and awareness at the RDE-Regional Disability with bonus Seniors Expo!"},{"marketVariantId":"Portuguese","attributeIdProductComment":"PRODTRANS ","attributeIdProductCommentDescription":"Product Description Translation","sequenceNumber":"100","attributeIdLanguageWritten":"PORT-EUR","attributeIdLanguageWrittenDescription":"Portuguese","commentText":"Junte-se a eles na RDE-Regional Disability with bônus Seniors Expo para um dia repleto de inspiração, informação e capacitação. Este evento presencial reúne uma comunidade diversificada de indivíduos, famílias e organizações dedicadas a apoiar pessoas com deficiência e o setor de cuidados a idosos.\n\nDescubra as mais recentes inovações em tecnologia assistiva, explore provedores de serviços e conecte-se com pessoas que pensam como você. Aprenda sobre opções de recreação acessíveis, oportunidades de emprego e recursos para melhorar seu bem-estar.\n\nQuer você seja uma pessoa com deficiência, um cuidador ou um profissional da área, a RDE-Regional Disability with Bonus Seniors Expo é o lugar para estar. Venha fazer parte de um ambiente acolhedor e inclusivo onde você pode adquirir conhecimento, fazer conexões e celebrar as habilidades de todos os indivíduos.\n\nMarque na sua agenda e prepare-se para abraçar um dia de conhecimento e conscientização na RDE-Regional Disability com bônus Seniors Expo!"},{"marketVariantId":"Chinese Simplified","attributeIdProductComment":"PRODTRANS ","attributeIdProductCommentDescription":"Product Description Translation","sequenceNumber":"100","attributeIdLanguageWritten":"CHINESE-S","attributeIdLanguageWrittenDescription":"Chinese Simplified","commentText":"与他们一起参加 RDE-地区残疾人活动，并享受老年人博览会奖金，度过充满灵感、信息和赋权的一天。这项面对面的活动汇集了由致力于支持残疾人和老年护理部门的个人、家庭和组织组成的多元化社区。\n\n发现辅助技术的最新创新，探索服务提供商，并与志趣相投的人建立联系。了解方便的娱乐选择、就业机会和资源，以增强您的福祉。\n\n无论您是残疾人、护理人员还是该领域的专业人士，RDE-地区残疾人奖金老年人博览会都是您的理想去处。欢迎来到这个热情、包容的环境中，在这里您可以获取知识、建立联系并庆祝所有人的能力。\n\n标记您的日历，准备好在 RDE 地区残疾人活动中享受一天的洞察力和意识，并获得奖金老年人博览会！"},{"marketVariantId":"German","attributeIdProductComment":"PRODTRANS ","attributeIdProductCommentDescription":"Product Description Translation","sequenceNumber":"100","attributeIdLanguageWritten":"GERMAN","attributeIdLanguageWrittenDescription":"German","commentText":"Begleiten Sie sie auf der RDE-Regional Disability with Bonus Seniors Expo für einen Tag voller Inspiration, Informationen und Selbstbestimmung. Diese persönliche Veranstaltung bringt eine vielfältige Gemeinschaft von Einzelpersonen, Familien und Organisationen zusammen, die sich der Unterstützung von Menschen mit Behinderungen und dem Altenpflegesektor widmen.\n\nEntdecken Sie die neuesten Innovationen in der unterstützenden Technologie, erkunden Sie Dienstleister und vernetzen Sie sich mit Gleichgesinnten. Erfahren Sie mehr über barrierefreie Freizeitmöglichkeiten, Beschäftigungsmöglichkeiten und Ressourcen zur Verbesserung Ihres Wohlbefindens.\n\nEgal, ob Sie eine Person mit einer Behinderung, eine Pflegekraft oder ein Fachmann auf diesem Gebiet sind, die RDE-Regional Disability with Bonus Seniors Expo ist der richtige Ort für Sie. Seien Sie Teil einer einladenden und integrativen Umgebung, in der Sie Wissen erwerben, Kontakte knüpfen und die Fähigkeiten aller Menschen feiern können.\n\nMarkieren Sie Ihren Kalender und machen Sie sich bereit für einen Tag voller Einblicke und Sensibilisierung auf der RDE-Regional Disability with Bonus Seniors Expo!"},{"marketVariantId":"Spanish","attributeIdProductComment":"PRODTRANS ","attributeIdProductCommentDescription":"Product Description Translation","sequenceNumber":"100","attributeIdLanguageWritten":"SPAN-EUR","attributeIdLanguageWrittenDescription":"Spanish","commentText":"Únase a ellos en la RDE-Discapacidad Regional con Exposición adicional para personas mayores para un día lleno de inspiración, información y empoderamiento. Este evento presencial reúne a una comunidad diversa de personas, familias y organizaciones dedicadas a apoyar a las personas con discapacidades y al sector de atención a personas mayores.\n\nDescubra las últimas innovaciones en tecnología de asistencia, explore proveedores de servicios y conéctese con personas de ideas afines. Conozca opciones de recreación accesibles, oportunidades de empleo y recursos para mejorar su bienestar.\n\nSi usted es una persona con discapacidad, un cuidador o un profesional en el campo, la RDE-Exposición Regional de Discapacidad con bonificación para personas mayores es el lugar para estar. Ven y sé parte de un ambiente acogedor e inclusivo donde podrás adquirir conocimientos, hacer conexiones y celebrar las habilidades de todas las personas.\n\n¡Marque su calendario y prepárese para disfrutar de un día de conocimiento y concientización en la RDE-Discapacidad Regional con Exposición adicional para personas mayores!"},{"marketVariantId":"French","attributeIdProductComment":"PRODTRANS ","attributeIdProductCommentDescription":"Product Description Translation","sequenceNumber":"100","attributeIdLanguageWritten":"FRENCH","attributeIdLanguageWrittenDescription":"French","commentText":"Rejoignez-les au RDE-Regional Disability avec en prime une exposition sur les seniors pour une journée remplie d'inspiration, d'informations et d'autonomisation. Cet événement en personne rassemble une communauté diversifiée d'individus, de familles et d'organisations dédiées au soutien des personnes handicapées et du secteur des soins aux personnes âgées.\n\nDécouvrez les dernières innovations en matière de technologie d'assistance, explorez les fournisseurs de services et connectez-vous avec des personnes partageant les mêmes idées. Découvrez les options de loisirs accessibles, les opportunités d’emploi et les ressources pour améliorer votre bien-être.\n\nQue vous soyez une personne en situation de handicap, un soignant ou un professionnel du domaine, le RDE-Expo Régionale Handicap avec bonus Seniors est le rendez-vous incontournable. Venez faire partie d'un environnement accueillant et inclusif où vous pourrez acquérir des connaissances établir des liens et célébrer les capacités de tous.\n\nMarquez votre calendrier et préparez-vous à vivre une journée d'information et de sensibilisation au RDE-Régional Handicap avec en prime l'Expo Seniors !"},{"marketVariantId":"Japanese","attributeIdProductComment":"PRODTRANS ","attributeIdProductCommentDescription":"Product Description Translation","sequenceNumber":"100","attributeIdLanguageWritten":"JAPANESE","attributeIdLanguageWrittenDescription":"Japanese","commentText":"RDE-Regional Disability に参加して、シニアエキスポの特典付きで、インスピレーション、情報、エンパワーメントに満ちた 1 日をお過ごしください。この対面イベントには、障害のある人々や高齢者介護分野のサポートに専念する個人、家族、組織からなる多様なコミュニティが集まります。\n\n支援技術の最新のイノベーションを発見し、サービスプロバイダーを探索し、同じ考えを持つ人々とつながりましょう。健康を増進するための、利用可能なレクリエーションのオプション、雇用の機会、リソースについて学びましょう。\n\nあなたが障害者、介護者、またはその分野の専門家であっても、特典付きの RDE-地域障害者エキスポは最適な場所です。知識を獲得し、つながりを築き、すべての個人の能力を称賛できる、歓迎的で包括的な環境に参加しませんか。\n\nカレンダーに印を付けて、ボーナス付きシニアエキスポ付きの RDE-Regional Disability で洞察と気づきを得る 1 日を過ごす準備をしましょう。"},{"marketVariantId":"Italian","attributeIdProductComment":"PRODTRANS ","attributeIdProductCommentDescription":"Product Description Translation","sequenceNumber":"100","attributeIdLanguageWritten":"ITALIAN","attributeIdLanguageWrittenDescription":"Italian","commentText":"Unisciti a loro all'RDE-Regional Disability with bonus Seniors Expo per una giornata ricca di ispirazione, informazioni e responsabilizzazione. Questo evento dal vivo riunisce una comunità diversificata di individui, famiglie e organizzazioni dedicate al sostegno delle persone con disabilità e del settore dell'assistenza agli anziani.\n\nScopri le ultime innovazioni nella tecnologia assistiva, esplora i fornitori di servizi e connettiti con persone che la pensano allo stesso modo. Scopri le opzioni ricreative accessibili, le opportunità di lavoro e le risorse per migliorare il tuo benessere.\n\nChe tu sia una persona con disabilità, un badante o un professionista del settore, la RDE-Disabilità regionale con bonus Seniors Expo è il posto dove stare. Vieni a far parte di un ambiente accogliente e inclusivo in cui puoi acquisire conoscenze, creare connessioni e celebrare le capacità di tutti gli individui.\n\nSegna sul tuo calendario e preparati ad abbracciare una giornata di approfondimento e consapevolezza alla RDE-Regional Disability con bonus Seniors Expo!"},{"marketVariantId":"Chinese Traditional","attributeIdProductComment":"PRODTRANS ","attributeIdProductCommentDescription":"Product Description Translation","sequenceNumber":"100","attributeIdLanguageWritten":"CHINESE-T","attributeIdLanguageWrittenDescription":"Chinese Traditional","commentText":"與他們一起參加 RDE-地區殘疾人活動，並享受老年人博覽會獎金，度過充滿靈感、訊息和賦權的一天。這項面對面的活動匯集了由致力於支持殘疾人和老年護理部門的個人、家庭和組織組成的多元化社區。\n\n發現輔助科技的最新創新，探索服務供應商，並與志趣相投的人建立聯繫。了解方便的娛樂選擇、就業機會和資源，以增強您的福祉。\n\n無論您是殘疾人、護理人員還是該領域的專業人士，RDE-地區殘疾人獎金老年人博覽會都是您的理想去處。歡迎來到這個熱情、包容的環境中，您可以獲得知識、建立聯繫並慶祝所有人的能力。\n\n標記您的日曆，準備好在 RDE 地區殘疾人活動中享受一天的洞察力和意識，並獲得獎金老年人博覽會！"},{"marketVariantId":"Korean","attributeIdProductComment":"PRODTRANS ","attributeIdProductCommentDescription":"Product Description Translation","sequenceNumber":"100","attributeIdLanguageWritten":"KOREAN","attributeIdLanguageWrittenDescription":"Korean","commentText":"영감 정보 및 권한 부여로 가득 찬 하루 동안 보너스 노인 엑스포가 포함된 RDE-지역 장애에 참여하십시오. 이 오프라인 이벤트에는 장애인과 노인 간호 부문을 지원하는 데 전념하는 개인 가족 조직의 다양한 커뮤니티가 한 자리에 모입니다.\n\n보조 기술의 최신 혁신을 알아보고 서비스 제공업체를 탐색하고 같은 생각을 가진 사람들과 연결하세요. 귀하의 웰빙을 향상시키는 데 도움이 되는 접근 가능한 레크리에이션 옵션 고용 기회 및 자원에 대해 알아보십시오.\n\n장애인 간병인 해당 분야의 전문가 등 누구에게나 보너스 노인 엑스포가 포함된 RDE 지역 장애가 있는 곳입니다. 지식을 얻고 연결을 만들고 모든 개인의 능력을 축하할 수 있는 따뜻하고 포용적인 환경에 참여해 보세요.\n\n달력을 표시하고 보너스 노인 엑스포와 함께 RDE-지역 장애에서 통찰력과 인식의 하루를 받아들일 준비를 하십시오!"},{"marketVariantId":"Indonesian","attributeIdProductComment":"PRODTRANS ","attributeIdProductCommentDescription":"Product Description Translation","sequenceNumber":"100","attributeIdLanguageWritten":"INDONESIAN","attributeIdLanguageWrittenDescription":"Indonesian","commentText":"Bergabunglah dengan mereka di RDE-Regional Disability dengan bonus Seniors Expo untuk hari yang penuh dengan inspirasi, informasi, dan pemberdayaan. Acara tatap muka ini mempertemukan beragam komunitas individu, keluarga, dan organisasi yang berdedikasi untuk mendukung penyandang disabilitas dan sektor perawatan lansia.\n\nTemukan inovasi terbaru dalam teknologi bantu, jelajahi penyedia layanan, dan terhubung dengan individu yang berpikiran sama. Pelajari tentang pilihan rekreasi yang dapat diakses, peluang kerja, dan sumber daya untuk meningkatkan kesejahteraan Anda.\n\nApakah Anda seorang penyandang disabilitas, pengasuh, atau profesional di bidangnya, RDE-Regional Disability dengan bonus Seniors Expo adalah tempatnya. Datang dan jadilah bagian dari lingkungan yang ramah dan inklusif di mana Anda dapat memperoleh pengetahuan, menjalin koneksi, dan merayakan kemampuan semua individu.\n\nTandai kalender Anda dan bersiaplah untuk menyambut hari wawasan dan kesadaran di RDE-Regional Disability dengan bonus Seniors Expo!"}],"productSite":[{"siteName":"Cairns Show Grounds","attributeIdSiteType":"VENUE","attributeIdSiteTypeDescription":"Venue","productSiteAddressRelationship":[{"attributeIdAddress":"PHYSICAL","attributeIdAddressDescription":"Physical","addressLine1":"109-127 Mulgrave Road","addressLine2":"","suburbName":"","cityName":"Parramatta Park","areaName":"","stateName":"Queensland","countryName":"Australia","addressPostalCode":"4870","overrideDomesticRegionFlag":"0","geocodeGdaLatitude":"-16.92738079999999","geocodeGdaLongitude":"145.7650172","productSiteAddressStreetDirectoryRelationship":""}],"productSiteAttributeRelationship":"","productSiteCommentRelationship":"","productSiteCommunicationRelationship":"","productSiteLicenceRelationship":"","productSiteRelatedSiteRelationship":"","productSiteMultimediaRelationship":"","productSiteContactRelationship":""}],"mediaLinks":[],"alternateNames":[{"name":"Let's Talk Events","kind":""},{"name":"RDE - Regional Disability & Seniors Expo","kind":""}],"internationalReach":"","rates":[{"ratesType":"","ratesTypeDescription":"","priceFrom":"","priceTo":"","free":"true","rateComment":""}],"deals":[],"jobVacancies":[],"weather":"","menuUrl":"","winelistUrl":"","doesServeMeal":"","openingTime":{"openingTimeType":"","seasonalPeriods":[],"openingTimeComment":"","exceptions":{"exceptionPeriod":"","periods":[]}},"productProximity":[],"productWidget":[],"services":[],"verticalClassifications":[{"productTypeId":"EXHIBIT","productTypeDescription":"Exhibition and Shows"},{"productTypeId":"EVTCOMNTY","productTypeDescription":"Community Event"}],"pageURL":"/au/en/things-to-do/events/p-6555abdd590daa642e37d39c-rderegional-disability-expo-with-bonus-seniors-expocairns","classificationLayer":[{"attributeId":"markets-and-community"}]}}]},"disabledClassifications":["classes-and-workshops","participation-and-endurance","business-event","food-and-wine","music-and-festivals"]}